APP_ENV=development
APP_PORT=3004
APP_VERSION=dev
DATABASE_URL=postgres://app:app@postgres:5432/pg_analytics?sslmode=disable
REDIS_URL=redis://redis:6379/0
MANAGEMENT_API_KEY=local-management-key
APP_AUTO_MIGRATE=true
APP_AUTO_SEED=true
MAX_REPORT_RANGE_DAYS=366
RECOMPUTE_LOCK_TTL=15m
RECOMPUTE_WORKERS=1
RECOMPUTE_QUEUE_SIZE=64
HTTP_READ_TIMEOUT=10s
HTTP_WRITE_TIMEOUT=20s
HTTP_SHUTDOWN_TIMEOUT=15s
